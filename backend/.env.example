APP_NAME=NunuJal API
APP_ENV=development
FRONTEND_URL=http://localhost:5073
LOCAL_FRONTEND_URL=http://localhost:5073
SERVER_PORT=8028
GOOGLE_REDIRECT_URI=http://localhost:8028/api/auth/google/callback
JWT_SECRET=dev-jwt-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
SESSION_SECRET=dev-session-secret
GOOGLE_CLIENT_ID=dummy-google-client-id
GOOGLE_CLIENT_SECRET=dummy-google-client-secret
DATABASE_URL=postgresql+psycopg://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:YOUR_DB_PORT/YOUR_DB_NAME
CONTRIBUTION_AI_PROVIDER=google_gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
CONTRIBUTION_MODEL_NAME=gemini-2.5-flash
GOOGLE_GENAI_THINKING_LEVEL=HIGH
GOOGLE_GENAI_THINKING_BUDGET=-1
GOOGLE_GENAI_USE_RESPONSE_SCHEMA=true
OLLAMA_BASE_URL=http://nunujal.o-r.kr:12812
CONTRIBUTION_PROMPT_VERSION=v1
CONTRIBUTION_POLICY_VERSION=v1
CONTRIBUTION_REQUEST_TIMEOUT_SECONDS=600
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=YOUR_S3_BUCKET_NAME
S3_UPLOAD_PREFIX=uploads
S3_PRESIGNED_EXPIRE_SECONDS=300
MAX_UPLOAD_TOTAL_BYTES=52428800
